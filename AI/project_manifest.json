{
  "project": "LightchangerT",
  "version": "1.0.0",
  "description": "Network-based gaming console detection with LED color feedback",
  "branch_type": "python",
  "platform": {
    "primary": "Raspberry Pi",
    "secondary": "General Linux SoC",
    "language": "Python 3"
  },

  "pipeline": {
    "setup": [
      "Install Python 3.8+",
      "Run: pip install -r requirements.txt (if exists)",
      "Configure config.json with network settings",
      "Test: python main.py"
    ],
    "testing": [
      "python -m py_compile *.py",
      "python -m unittest discover (if tests exist)"
    ],
    "build": "Native Python - no build step required",
    "deploy": [
      "Set execution bit: chmod +x main.py",
      "Run as service or manually: python main.py"
    ]
  },

  "sync_instructions": {
    "description": "Guidelines for syncing features between Python (main) and ESP32 branches",
    "principles": [
      "Each branch maintains independent implementation appropriate for its platform",
      "Feature parity is goal, not exact code parity",
      "Manifest updates should be mirrored to both branches"
    ],
    "when_to_sync": [
      "Adding new device detection methods",
      "Adding new supported brands",
      "Changing detection logic/priority algorithms",
      "Adding new configuration options",
      "Fixing bugs that apply to both platforms"
    ],
    "sync_process": {
      "step1": "Implement feature on originating branch",
      "step2": "Test thoroughly on that platform",
      "step3": "Port logic to other branch (adapt code, not copy-paste)",
      "step4": "Test on second platform",
      "step5": "Update both manifests to reflect new feature",
      "step6": "Commit with descriptive message mentioning both branches"
    },
    "do_not_sync": [
      "Platform-specific hardware code (LED drivers)",
      "Network stack differences (WiFi vs Ethernet)",
      "Memory management differences",
      "Build system configurations"
    ]
  },

  "architecture": {
    "components": {
      "main.py": "Entry point and state machine",
      "scanner.py": "Network device discovery (ARP/MAC OUI)",
      "liveness.py": "ICMP ping validation",
      "steam_detector.py": "Special Steam detection (mDNS/port probe)",
      "led_controller.py": "LED color management (FastLED/NeoPixel/RPi_WS281x)",
      "web_config.py": "HTTP configuration UI",
      "config_manager.py": "Thread-safe config loader"
    },
    "flow": "Scan -> Verify Liveness -> Check Steam -> Determine Priority -> Set LED"
  },

  "detection": {
    "methods": ["MAC_OUI", "STATIC_LIST", "PORT_PROBE", "MDNS"],
    "validation": "ICMP_Ping",
    "deep_sleep_handling": "Considered offline if ping fails",
    "priority_logic": "Last online device wins"
  },

  "color_mapping": {
    "sony": "blue",
    "microsoft": "green",
    "nintendo": "red",
    "steam": "light_blue",
    "nvidia": "light_green",
    "default": "white"
  },

  "current_phase": "Production",
  "last_updated": "2025-05-08"
}